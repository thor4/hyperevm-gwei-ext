{
  "manifest_version": 3,
  "name": "HyperEVM Gas Tracker",
  "version": "1.0",
  "description": "Tracks current GWEI values on the HyperEVM blockchain.",
  "permissions": [
    "storage",
    "alarms",
    "https://rpc.hyperliquid.xyz/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
